{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "data",
    "source": "Atlas\nThivarrakesh OS",
    "padding": {
      "right": 2
    }
  },
  "display": {
    "separator": "  "
  },
  "modules": [
    "os",
    "memory",
    "shell",
    "terminal",
    "theme",
    {
      "type": "command",
      "key": "✓ Python",
      "text": "command -v python3 >/dev/null && printf ready || printf missing"
    },
    {
      "type": "command",
      "key": "✓ Node",
      "text": "command -v node >/dev/null && printf ready || printf missing"
    },
    {
      "type": "command",
      "key": "✓ Docker",
      "text": "command -v docker >/dev/null && printf ready || printf missing"
    },
    {
      "type": "command",
      "key": "✓ Claude",
      "text": "command -v claude >/dev/null && printf ready || printf missing"
    },
    {
      "type": "command",
      "key": "✓ Codex",
      "text": "command -v codex >/dev/null && printf ready || printf missing"
    },
    {
      "type": "command",
      "key": "✓ Git",
      "text": "command -v git >/dev/null && printf ready || printf missing"
    },
    {
      "type": "command",
      "key": "✓ Atlas",
      "text": "command -v atlas >/dev/null && printf ready || printf managed"
    },
    "colors"
  ]
}
