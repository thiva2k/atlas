# Atlas HUD design tokens — the single source of truth (RFC-0034).
# Every surface (Plymouth boot, SDDM/lock, terminal, KDE color scheme) derives its
# colors from these. Change a value here, regenerate/re-apply consumers — never
# hand-edit a hex in a downstream file.

# ——— Navy ramp (ground → panel) ———
ATLAS_NAVY_900=#0a0e14   # near-black ground floor (cursor-text, deepest bg)
ATLAS_NAVY_800=#0d1420   # base ground
ATLAS_NAVY_700=#0f141b   # panel / terminal background
ATLAS_NAVY_600=#111d2b   # raised panel
ATLAS_NAVY_500=#16253a   # node fill / chip
ATLAS_NAVY_400=#243247   # hairline / border / split divider

# ——— Ink / dim ———
ATLAS_INK=#e6edf3        # primary text
ATLAS_DIM=#7d8aa0        # telemetry / muted text
ATLAS_DIM_2=#54627a      # deep muted

# ——— Accent (locked) ———
ATLAS_ACCENT=#5aa2ff     # primary structural blue (was #4ea1ff — migrated & retired)
ATLAS_ACCENT_DEEP=#3f7fe0
ATLAS_CYAN=#57e5ff       # LIVE glow — scarce, ONE element per surface (cursor, node, focus)
ATLAS_WARM=#ff6b5a       # error only (cross-surface unity)

# ——— Selection ———
ATLAS_SELECTION_BG=#1f3252
ATLAS_SELECTION_FG=#f8fafc

# ——— Type ———
ATLAS_FONT_SANS="Inter"                       # human layer (Plasma UI, wordmark, clock)
ATLAS_FONT_MONO="JetBrainsMono Nerd Font"     # machine layer (terminal, readouts, prompt)

# ——— Signature glyph ———
ATLAS_NODE_GLYPH="◐"     # the orbital node: ignites at boot, frames the lock clock,
                         # marks every ready shell line. One symbol, every surface.

# ——— Motion scale (ms) ———
ATLAS_MOTION_FAST=180
ATLAS_MOTION_STANDARD=320
ATLAS_MOTION_CINEMATIC=640
ATLAS_MOTION_AMBIENT=240000   # armillary drift, one revolution (linear)
